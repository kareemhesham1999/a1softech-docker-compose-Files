GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_SERVER_ROOT_URL=http://YOUR_MONITORING_SERVER_IP:3000
GF_SERVER_DOMAIN=YOUR_MONITORING_SERVER_IP
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.your-email-provider.com:587
GF_SMTP_USER=YOUR_SMTP_USER
GF_SMTP_PASSWORD=YOUR_SMTP_PASSWORD
GF_SMTP_FROM_ADDRESS=hcm-alerts@your-company.com
GF_SMTP_FROM_NAME=HCM Monitoring
GF_SMTP_STARTTLS_POLICY=MandatoryStartTLS
GF_UNIFIED_ALERTING_ENABLED=true
GF_ALERTING_ENABLED=false
GF_FEATURE_TOGGLES_ENABLE=traceqlEditor tempoServiceGraph tempoSearch tempoBackendSearch
GF_LOG_MODE=console
GF_LOG_LEVEL=warn
